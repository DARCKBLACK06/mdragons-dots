[global]
    monitor = 0
    follow = mouse

    width = 320
    height = (0, 100)
    origin = top-right
    offset = (15, 40)

    notification_limit = 5

    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 1

    transparency = 10
    corner_radius = 10
    frame_width = 2
    gap_size = 8

    font = JetBrainsMono Nerd Font 10

    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center

    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle

    stack_duplicates = true
    hide_duplicate_count = false

    idle_threshold = 120
    sort = yes

    markup = full
    history_length = 20

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    sticky_history = yes

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#313244"
    timeout = 3

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 6

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0

[whatsapp]
    appname = whatsapp
    background = '#1e1e2e'
    foreground = '#a6e3a1'
    frame_color = '#25D366'
    timeout = 8

script = ~/.config/dunst/scripts/notify.sh

